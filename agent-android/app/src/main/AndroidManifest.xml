<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android">

    <uses-permission android:name="android.permission.INTERNET" />

    <queries>
        <package android:name="com.plexapp.android" />
        <package android:name="org.videolan.vlc" />
        <package android:name="com.mxtech.videoplayer.ad" />
        <package android:name="com.mxtech.videoplayer.pro" />
        <package android:name="ar.tvplayer.tv" />
        <package android:name="com.amazon.firetv.tvplayer" />
        <package android:name="tv.tivimate.appplayer" />
        <package android:name="org.xbmc.kodi" />
        <package android:name="tv.kodi.kodi" />
    </queries>
    <uses-permission android:name="android.permission.FOREGROUND_SERVICE" />
    <uses-permission android:name="android.permission.RECEIVE_BOOT_COMPLETED" />
    <!-- Whitelist pour les "Background activity launches" sur Android 10+.
         Sans ça, ActivityTaskManager abort le startActivity de PlexLauncher depuis
         le foreground service quand une autre app (YouTube...) est au premier plan. -->
    <uses-permission android:name="android.permission.SYSTEM_ALERT_WINDOW" />

    <!-- Declare as a Leanback app for Android TV / Fire TV -->
    <uses-feature android:name="android.software.leanback" android:required="false" />
    <uses-feature android:name="android.hardware.touchscreen" android:required="false" />

    <application
        android:allowBackup="true"
        android:label="@string/app_name"
        android:supportsRtl="true"
        android:theme="@style/Theme.AppCompat.NoActionBar"
        android:networkSecurityConfig="@xml/network_security_config">

        <activity
            android:name=".MainActivity"
            android:exported="true"
            android:label="@string/app_name">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
                <!-- TV launcher -->
                <category android:name="android.intent.category.LEANBACK_LAUNCHER" />
            </intent-filter>
        </activity>

        <service
            android:name=".HubService"
            android:exported="false"
            android:foregroundServiceType="connectedDevice" />

        <!-- Boilerplate empty NotificationListenerService.
             Sa seule raison d'être : permettre à l'utilisateur d'activer
             "Accès aux notifications" pour Hub Agent, ce qui débloque
             MediaSessionManager.getActiveSessions() (utilisé pour stopper
             un media en cours sur une autre app avant de lancer Plex/IPTV). -->
        <service
            android:name=".HubNotificationListener"
            android:exported="true"
            android:permission="android.permission.BIND_NOTIFICATION_LISTENER_SERVICE">
            <intent-filter>
                <action android:name="android.service.notification.NotificationListenerService" />
            </intent-filter>
        </service>

        <receiver
            android:name=".BootReceiver"
            android:exported="true">
            <intent-filter>
                <action android:name="android.intent.action.BOOT_COMPLETED" />
            </intent-filter>
        </receiver>

    </application>

</manifest>
