<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#111118">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="48dp">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Hub MediaCenter — Agent"
            android:textSize="22sp"
            android:textColor="#ffffff"
            android:layout_marginBottom="32dp" />

        <!-- Hub connection -->
        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
            android:text="HUB" android:textColor="#7777aa" android:textSize="11sp"
            android:letterSpacing="0.15" android:layout_marginBottom="8dp"/>

        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
            android:text="WebSocket URL" android:textColor="#888888" android:textSize="13sp"/>
        <EditText android:id="@+id/etHubUrl"
            android:layout_width="match_parent" android:layout_height="wrap_content"
            android:textColor="#ffffff" android:background="#1e1e2e" android:padding="12dp"
            android:inputType="textUri" android:textSize="15sp" android:layout_marginBottom="12dp"
            android:hint="ws://192.168.1.15:8020" android:textColorHint="#444455"/>

        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
            android:text="Device Name" android:textColor="#888888" android:textSize="13sp"/>
        <EditText android:id="@+id/etDeviceName"
            android:layout_width="match_parent" android:layout_height="wrap_content"
            android:textColor="#ffffff" android:background="#1e1e2e" android:padding="12dp"
            android:inputType="text" android:textSize="15sp" android:layout_marginBottom="28dp"
            android:hint="Shield Salon" android:textColorHint="#444455"/>

        <!-- Xtream Codes / Elon IPTV -->
        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
            android:text="XTREAM CODES / IPTV" android:textColor="#7777aa" android:textSize="11sp"
            android:letterSpacing="0.15" android:layout_marginBottom="8dp"/>

        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
            android:text="Server URL" android:textColor="#888888" android:textSize="13sp"/>
        <EditText android:id="@+id/etXtreamServer"
            android:layout_width="match_parent" android:layout_height="wrap_content"
            android:textColor="#ffffff" android:background="#1e1e2e" android:padding="12dp"
            android:inputType="textUri" android:textSize="15sp" android:layout_marginBottom="12dp"
            android:hint="http://elon-iptv.com:8080" android:textColorHint="#444455"/>

        <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
            android:orientation="horizontal" android:layout_marginBottom="12dp">
            <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content"
                android:layout_weight="1" android:orientation="vertical" android:layout_marginEnd="8dp">
                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:text="Username" android:textColor="#888888" android:textSize="13sp"/>
                <EditText android:id="@+id/etXtreamUser"
                    android:layout_width="match_parent" android:layout_height="wrap_content"
                    android:textColor="#ffffff" android:background="#1e1e2e" android:padding="12dp"
                    android:inputType="text" android:textSize="15sp"
                    android:hint="user" android:textColorHint="#444455"/>
            </LinearLayout>
            <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content"
                android:layout_weight="1" android:orientation="vertical">
                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:text="Password" android:textColor="#888888" android:textSize="13sp"/>
                <EditText android:id="@+id/etXtreamPass"
                    android:layout_width="match_parent" android:layout_height="wrap_content"
                    android:textColor="#ffffff" android:background="#1e1e2e" android:padding="12dp"
                    android:inputType="textPassword" android:textSize="15sp"
                    android:hint="password" android:textColorHint="#444455"/>
            </LinearLayout>
        </LinearLayout>

        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
            android:text="Stream extension (ts or m3u8)" android:textColor="#888888" android:textSize="13sp"/>
        <EditText android:id="@+id/etXtreamExt"
            android:layout_width="match_parent" android:layout_height="wrap_content"
            android:textColor="#ffffff" android:background="#1e1e2e" android:padding="12dp"
            android:inputType="text" android:textSize="15sp" android:layout_marginBottom="32dp"
            android:hint="ts" android:textColorHint="#444455"/>

        <!-- Buttons -->
        <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
            android:orientation="horizontal" android:layout_marginBottom="20dp">
            <Button android:id="@+id/btnSave"
                android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1"
                android:text="Save" android:backgroundTint="#2a2a4e" android:textColor="#ffffff"
                android:layout_marginEnd="8dp"/>
            <Button android:id="@+id/btnStart"
                android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1"
                android:text="Start" android:backgroundTint="#1a5e2a" android:textColor="#ffffff"
                android:layout_marginEnd="8dp"/>
            <Button android:id="@+id/btnStop"
                android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1"
                android:text="Stop" android:backgroundTint="#5e1a1a" android:textColor="#ffffff"/>
        </LinearLayout>

        <TextView android:id="@+id/tvStatus"
            android:layout_width="match_parent" android:layout_height="wrap_content"
            android:textColor="#888888" android:textSize="13sp" android:padding="12dp"
            android:background="#1e1e2e" android:text="Agent stopped"/>

    </LinearLayout>
</ScrollView>
