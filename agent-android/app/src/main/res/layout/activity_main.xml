<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#0d0d14">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="48dp">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Hub MediaCenter — Agent"
            android:textSize="24sp"
            android:textStyle="bold"
            android:textColor="#ffffff"
            android:layout_marginBottom="36dp" />

        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
            android:text="CONNEXION AU HUB" android:textColor="#aaaadd" android:textSize="12sp"
            android:textStyle="bold" android:letterSpacing="0.15" android:layout_marginBottom="10dp"/>

        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
            android:text="WebSocket URL" android:textColor="#cccccc" android:textSize="14sp"
            android:layout_marginBottom="4dp"/>
        <EditText android:id="@+id/etHubUrl"
            android:layout_width="match_parent" android:layout_height="wrap_content"
            android:textColor="#ffffff" android:background="#1e1e30" android:padding="14dp"
            android:inputType="textUri" android:textSize="16sp" android:layout_marginBottom="16dp"
            android:hint="ws://192.168.1.15:8020" android:textColorHint="#666688"/>

        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
            android:text="Nom de l'appareil" android:textColor="#cccccc" android:textSize="14sp"
            android:layout_marginBottom="4dp"/>
        <EditText android:id="@+id/etDeviceName"
            android:layout_width="match_parent" android:layout_height="wrap_content"
            android:textColor="#ffffff" android:background="#1e1e30" android:padding="14dp"
            android:inputType="text" android:textSize="16sp" android:layout_marginBottom="36dp"
            android:hint="Shield Salon" android:textColorHint="#666688"/>

        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
            android:text="Les credentials IPTV et les préférences d'apps se configurent\ndepuis le Hub (192.168.1.15:3050 → Devices)."
            android:textColor="#666688" android:textSize="13sp" android:layout_marginBottom="36dp"
            android:lineSpacingExtra="4dp"/>

        <!-- Buttons -->
        <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
            android:orientation="horizontal" android:layout_marginBottom="24dp">
            <Button android:id="@+id/btnSave"
                android:layout_width="0dp" android:layout_height="56dp" android:layout_weight="1"
                android:text="SAVE" android:backgroundTint="#3a3a6e" android:textColor="#ffffff"
                android:textSize="15sp" android:textStyle="bold"
                android:layout_marginEnd="8dp"/>
            <Button android:id="@+id/btnStart"
                android:layout_width="0dp" android:layout_height="56dp" android:layout_weight="1"
                android:text="START" android:backgroundTint="#1a7a30" android:textColor="#ffffff"
                android:textSize="15sp" android:textStyle="bold"
                android:layout_marginEnd="8dp"/>
            <Button android:id="@+id/btnStop"
                android:layout_width="0dp" android:layout_height="56dp" android:layout_weight="1"
                android:text="STOP" android:backgroundTint="#7a1a1a" android:textColor="#ffffff"
                android:textSize="15sp" android:textStyle="bold"/>
        </LinearLayout>

        <TextView android:id="@+id/tvStatus"
            android:layout_width="match_parent" android:layout_height="wrap_content"
            android:textColor="#dddddd" android:textSize="14sp" android:padding="16dp"
            android:background="#1e1e30" android:text="Agent arrêté"/>

        <TextView android:id="@+id/tvNotifWarning"
            android:layout_width="match_parent" android:layout_height="wrap_content"
            android:textColor="#0d0d14" android:textSize="14sp" android:padding="16dp"
            android:background="#ffb84d" android:textStyle="bold"
            android:layout_marginTop="12dp"
            android:focusable="true" android:clickable="true"
            android:visibility="gone"
            android:text="⚠ Activer 'Accès aux notifications' — touchez ici"/>

    </LinearLayout>
</ScrollView>
