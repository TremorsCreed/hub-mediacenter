<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="horizontal"
    android:background="@drawable/overlay_player_bg"
    android:paddingStart="20dp"
    android:paddingEnd="32dp"
    android:paddingTop="14dp"
    android:paddingBottom="14dp"
    android:gravity="center_vertical"
    android:elevation="16dp">

    <FrameLayout
        android:id="@+id/overlayPlayerImageFrame"
        android:layout_width="100dp"
        android:layout_height="100dp"
        android:background="@drawable/overlay_poster_bg">

        <ImageView
            android:id="@+id/overlayPlayerImage"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:scaleType="fitCenter"
            android:padding="6dp"
            android:contentDescription="thumbnail" />

    </FrameLayout>

    <LinearLayout
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_weight="1"
        android:orientation="vertical"
        android:layout_marginStart="18dp"
        android:gravity="center_vertical">

        <TextView
            android:id="@+id/overlayPlayerApp"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:textColor="#f59e0b"
            android:textSize="11sp"
            android:textStyle="bold"
            android:letterSpacing="0.15"
            android:text="HUB MEDIACENTER" />

        <TextView
            android:id="@+id/overlayPlayerTitle"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:textColor="#ffffff"
            android:textSize="20sp"
            android:textStyle="bold"
            android:fontFamily="sans-serif-medium"
            android:layout_marginTop="2dp"
            android:maxLines="1"
            android:ellipsize="end"
            android:text="Titre du film" />

        <TextView
            android:id="@+id/overlayPlayerMessage"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:textColor="#cbd5e1"
            android:textSize="13sp"
            android:layout_marginTop="4dp"
            android:maxLines="2"
            android:ellipsize="end"
            android:text="En lecture" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:layout_marginTop="8dp">

            <TextView
                android:id="@+id/overlayPlayerPosition"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textColor="#94a3b8"
                android:textSize="11sp"
                android:fontFamily="monospace"
                android:text="" />

            <ProgressBar
                android:id="@+id/overlayPlayerProgress"
                style="?android:attr/progressBarStyleHorizontal"
                android:layout_width="0dp"
                android:layout_height="4dp"
                android:layout_weight="1"
                android:layout_marginStart="10dp"
                android:layout_marginEnd="10dp"
                android:max="1000"
                android:progress="0"
                android:progressTint="#f59e0b"
                android:progressBackgroundTint="#2a2a3a"
                android:visibility="gone" />

            <TextView
                android:id="@+id/overlayPlayerDuration"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textColor="#94a3b8"
                android:textSize="11sp"
                android:fontFamily="monospace"
                android:text="" />

        </LinearLayout>

    </LinearLayout>

</LinearLayout>
